# =============================================================================
# Money App 2026 — Environment Variables
# =============================================================================

# Site password (optional — protects the app behind a simple password gate)
VITE_SITE_PASSWORD=shoryuken

# =============================================================================
# Supabase Configuration (required for Google auth / cloud sync)
# =============================================================================
# 1. Create a free project at https://supabase.com/dashboard
# 2. Go to Project Settings → API
# 3. Copy the "Project URL" and "anon public" key below
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# Google OAuth Setup (in Supabase + Google Cloud Console)
# =============================================================================
# 1. In Supabase Dashboard → Authentication → Providers → Google → Enable
# 2. Go to https://console.cloud.google.com/apis/credentials
# 3. Create an OAuth 2.0 Client ID:
#    - Application type: Web application
#    - Authorized redirect URI:
#      https://<your-supabase-project>.supabase.co/auth/v1/callback
# 4. Copy the Client ID and Client Secret into Supabase's Google provider config
# 5. (Optional) Configure OAuth consent screen with your app name
#
# For Vercel deployment:
# - Add VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY in Vercel Dashboard
#   → Settings → Environment Variables
# - Redeploy after adding env vars
